{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "types": ["vite/client", "node"]
  },
  "include": ["ui.ts", "bot.ts", "engine.ts", "engine/**/*.ts", "catalog.ts", "demo.ts", "test/**/*.ts", "server/**/*.ts", "client/**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
